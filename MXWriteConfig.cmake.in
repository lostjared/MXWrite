@PACKAGE_INIT@
include(CMakeFindDependencyMacro)
find_dependency(Threads)
find_dependency(PkgConfig)

if(NOT TARGET PkgConfig::FFMPEG)
    pkg_check_modules(FFMPEG REQUIRED IMPORTED_TARGET
        libavcodec>=58.0.0
        libavformat>=58.0.0
        libavutil>=56.0.0
        libswscale>=5.0.0
    )
endif()

set(MXWrite_INCLUDE_DIR "@CMAKE_INSTALL_PREFIX@/@CMAKE_INSTALL_INCLUDEDIR@")
set(MXWrite_LIBRARY_DIR "@CMAKE_INSTALL_PREFIX@/@CMAKE_INSTALL_LIBDIR@")
if(NOT EXISTS "${MXWrite_INCLUDE_DIR}")
    message(FATAL_ERROR "File or directory referenced by variable MXWrite_INCLUDE_DIR does not exist!")
endif()
include("${CMAKE_CURRENT_LIST_DIR}/MXWriteTargets.cmake")
check_required_components(MXWrite)
set(MXWrite_INCLUDE_DIRS "${MXWrite_INCLUDE_DIR}")
set(MXWrite_LIBRARIES MXWrite::mxwrite)
